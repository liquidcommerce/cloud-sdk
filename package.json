{
 "name": "@liquidcommerceteam/cloud-sdk",
 "version": "1.10.0-beta.3",
 "description": "LiquidCommerce Cloud SDK",
 "main": "./dist/index.cjs",
 "module": "./dist/index.esm.js",
 "browser": "./umd/liquidcommerce-cloud-sdk.js",
 "types": "./dist/types/index.d.ts",
 "packageManager": "pnpm@10.30.3",
 "exports": {
  ".": {
   "import": {
    "types": "./dist/types/index.d.ts",
    "default": "./dist/index.esm.js"
   },
   "require": {
    "types": "./dist/types/index.d.ts",
    "default": "./dist/index.cjs"
   },
   "node": {
    "types": "./dist/types/index.d.ts",
    "default": "./dist/liquidcommerce-cloud-sdk.ssr.js"
   },
   "browser": {
    "types": "./dist/types/index.d.ts",
    "default": "./umd/liquidcommerce-cloud-sdk.js"
   }
  }
 },
 "files": [
  "dist",
  "umd"
 ],
 "type": "module",
 "sideEffects": false,
 "scripts": {
  "build": "rollup -c --environment NODE_ENV:production",
  "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
  "dev": "rollup -c --environment NODE_ENV:development -w",
  "test": "vitest run",
  "test:watch": "vitest",
  "test:coverage": "vitest run --coverage",
  "lint": "pnpm biome lint --write",
  "format": "biome format --write",
  "check": "pnpm biome check --write .",
  "fl": "pnpm check && pnpm tsc --noEmit",
  "clean:all": "rm -rf node_modules dist umd && pnpm install && pnpm build",
  "docs": "typedoc --out docs src",
  "prepublishOnly": "pnpm run build"
 },
 "keywords": [
  "liquidcommerce",
  "ecommerce",
  "alcohol",
  "beverage",
  "cloud-sdk"
 ],
 "author": "ReserveBar Tech",
 "license": "",
 "devDependencies": {
  "@biomejs/biome": "^2.4.5",
  "@rollup/plugin-commonjs": "^29.0.0",
  "@rollup/plugin-node-resolve": "^16.0.3",
  "@rollup/plugin-replace": "^6.0.3",
  "@rollup/plugin-terser": "^0.4.4",
  "@semantic-release/changelog": "^6.0.3",
  "@semantic-release/git": "^10.0.1",
  "@semantic-release/github": "^12.0.6",
  "@semantic-release/npm": "^13.1.5",
  "@types/node": "^25.3.3",
  "@vitest/coverage-v8": "^4.0.18",
  "conventional-changelog": "^7.2.0",
  "dotenv": "^17.3.1",
  "husky": "^9.1.7",
  "jest": "^30.2.0",
  "rollup": "^4.59.0",
  "rollup-plugin-livereload": "^2.0.5",
  "rollup-plugin-serve": "^3.0.0",
  "rollup-plugin-typescript2": "^0.36.0",
  "semantic-release": "^25.0.3",
  "ts-jest": "^29.4.6",
  "typedoc": "^0.28.17",
  "typescript": "^5.9.3",
  "vite": "^7.3.1",
  "vitest": "^4.0.18"
 },
 "engines": {
  "node": ">=22"
 },
 "pnpm": {
  "peerDependencyRules": {
   "ignoreMissing": []
  }
 },
 "dependencies": {
  "@stripe/stripe-js": "^7.9.0"
 }
}
